# Supabase (public — used by the Astro frontend)
PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJ...

# The following are NOT local env vars — set them as Supabase Edge Function secrets:
#   supabase secrets set TELEGRAM_TOKEN=... TELEGRAM_CHAT_ID=... WEBHOOK_SECRET=...
#
# TELEGRAM_TOKEN    — bot token from @BotFather
# TELEGRAM_CHAT_ID  — your Telegram chat id (see README for how to get it)
# WEBHOOK_SECRET    — random 30+ char string shared between Supabase Webhook and the function
