---
import { getCollection } from 'astro:content';
import BaseLayout from '../../components/BaseLayout.astro';
import GlassCard from '../../components/GlassCard.astro';

const allDates = await getCollection('dates');
const sorted = allDates.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Наши свидания">
  <main class="page">
    <header class="page-header">
      <a href={`${base}`} class="back-link">← На главную</a>
      <h1 class="page-title">Наши свидания</h1>
    </header>

    {sorted.length === 0 ? (
      <div class="empty-wrap">
        <GlassCard>
          <p class="empty-text">Первое свидание ещё впереди.</p>
        </GlassCard>
      </div>
    ) : (
      <ul class="date-list">
        {sorted.map((entry, index) => (
          <li
            class="date-item"
            style={`animation-delay: ${index * 80}ms`}
          >
            <a href={`${base}history/${entry.id}`} class="date-link">
              <GlassCard>
                <div class="date-entry">
                  {entry.data.heroPhoto && (
                    <div class="entry-photo-wrap">
                      <img
                        src={entry.data.heroPhoto}
                        alt={entry.data.title}
                        class="entry-photo"
                        loading="lazy"
                        width="400"
                        height="200"
                      />
                    </div>
                  )}
                  <div class="entry-body">
                    <time class="entry-date">
                      {new Intl.DateTimeFormat('ru-RU', {
                        day: 'numeric',
                        month: 'long',
                        year: 'numeric',
                      }).format(entry.data.date)}
                    </time>
                    <h2 class="entry-title">{entry.data.title}</h2>
                    {entry.data.location && (
                      <p class="entry-location">{entry.data.location}</p>
                    )}
                    {entry.data.mood && entry.data.mood.length > 0 && (
                      <div class="mood-tags">
                        {entry.data.mood.map((tag) => (
                          <span class="mood-tag">{tag}</span>
                        ))}
                      </div>
                    )}
                  </div>
                </div>
              </GlassCard>
            </a>
          </li>
        ))}
      </ul>
    )}
  </main>
</BaseLayout>

<style>
  .page {
    min-height: 100svh;
    background: var(--gradient-twilight);
    padding: var(--space-8) var(--space-6);
  }

  .page-header {
    max-width: 640px;
    margin: 0 auto var(--space-8);
  }

  .back-link {
    display: inline-block;
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    margin-bottom: var(--space-4);
    transition: color var(--duration-fast) var(--ease-soft);
  }

  .back-link:hover {
    color: rgba(255, 255, 255, 0.9);
  }

  .page-title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 400;
    color: #fff;
  }

  .empty-wrap {
    max-width: 480px;
    margin: 0 auto;
    animation: fadeUp var(--duration-slow) var(--ease-soft) both;
  }

  .empty-text {
    font-family: var(--font-hand);
    font-size: var(--text-lg);
    color: var(--color-plum);
    text-align: center;
  }

  .date-list {
    list-style: none;
    max-width: 640px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .date-item {
    animation: fadeUp var(--duration-slow) var(--ease-soft) both;
  }

  .date-link {
    display: block;
    text-decoration: none;
    color: inherit;
    transition: transform var(--duration-fast) var(--ease-soft);
  }

  @media (hover: hover) {
    .date-link:hover {
      transform: translateY(-2px);
    }
  }

  .date-entry {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .entry-photo-wrap {
    border-radius: calc(var(--radius-lg) - 1px) calc(var(--radius-lg) - 1px) 0 0;
    overflow: hidden;
    margin: calc(-1 * var(--space-8)) calc(-1 * var(--space-8)) var(--space-4);
  }

  .entry-photo {
    width: 100%;
    height: 160px;
    object-fit: cover;
    display: block;
  }

  .entry-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .entry-date {
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-plum);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .entry-title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 400;
    color: var(--color-ink);
    line-height: 1.2;
  }

  .entry-location {
    font-size: var(--text-sm);
    color: var(--color-ink);
    opacity: 0.7;
  }

  .mood-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-1);
  }

  .mood-tag {
    font-size: var(--text-xs);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-pill);
    background: var(--color-rose-soft);
    color: var(--color-plum);
    font-weight: 500;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>
