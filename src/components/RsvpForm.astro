---
interface Props {
  invitationId: string;
}
const { invitationId } = Astro.props;
---

<div class="rsvp-wrapper" id="rsvp-form-wrapper" data-invitation-id={invitationId}>

  <!-- hidden until Supabase check resolves -->
  <div class="rsvp-buttons" id="rsvp-buttons" style="display: none">
    <button type="button" class="btn-accept" data-response="accepted">
      Принимаю
    </button>
    <button type="button" class="btn-decline" data-response="declined">
      Отказываюсь
    </button>
  </div>

  <div class="rsvp-thanks" id="rsvp-thanks" style="display: none" aria-hidden="true">
    <p class="thanks-text" id="rsvp-thanks-text"></p>
  </div>

  <div class="rsvp-error" id="rsvp-error" style="display: none" aria-hidden="true">
    <p class="error-text">Что-то пошло не так. Попробуй ещё раз.</p>
  </div>

</div>

<style>
  .rsvp-wrapper {
    margin-top: var(--space-6);
  }

  .rsvp-buttons {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .btn-accept,
  .btn-decline {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 44px;
    padding: var(--space-3) var(--space-6);
    border-radius: var(--radius-pill);
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 500;
    cursor: pointer;
    border: none;
    transition: transform var(--duration-fast) var(--ease-soft),
                box-shadow var(--duration-fast) var(--ease-soft),
                opacity var(--duration-fast) var(--ease-soft);
  }

  .btn-accept {
    background: var(--color-rose);
    color: #fff;
    box-shadow: 0 4px 16px rgba(224, 102, 138, 0.35);
  }

  .btn-decline {
    background: transparent;
    border: 1px solid var(--color-plum);
    color: var(--color-plum);
  }

  .btn-accept:disabled,
  .btn-decline:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  @media (hover: hover) {
    .btn-accept:not(:disabled):hover,
    .btn-decline:not(:disabled):hover {
      transform: scale(1.02);
      box-shadow: var(--glass-shadow);
    }
  }

  .rsvp-thanks {
    text-align: center;
    padding-top: var(--space-4);
    border-top: 1px solid var(--glass-border);
  }

  .thanks-text {
    font-family: var(--font-hand);
    font-size: var(--text-xl);
    color: var(--color-plum);
  }

  .rsvp-error {
    text-align: center;
    margin-top: var(--space-4);
  }

  .error-text {
    font-size: var(--text-sm);
    color: var(--color-rose);
  }
</style>

<script>
  import { createClient } from '@supabase/supabase-js';

  (async () => {
    const wrapper = document.getElementById('rsvp-form-wrapper') as HTMLElement | null;
    if (!wrapper) return;

    const invitationId = wrapper.dataset.invitationId ?? '';
    const buttonsEl   = document.getElementById('rsvp-buttons')    as HTMLElement | null;
    const thanks      = document.getElementById('rsvp-thanks')      as HTMLElement | null;
    const thanksText  = document.getElementById('rsvp-thanks-text') as HTMLElement | null;
    const errorEl     = document.getElementById('rsvp-error')       as HTMLElement | null;

    const supabase = createClient(
      import.meta.env.PUBLIC_SUPABASE_URL,
      import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
    );

    function showThanks(response: string) {
      if (buttonsEl) buttonsEl.style.display = 'none';
      if (thanks && thanksText) {
        thanksText.textContent = response === 'accepted'
          ? 'Ура. Жду тебя. ♡'
          : 'Жаль. Но окей.';
        thanks.style.display = 'block';
        thanks.removeAttribute('aria-hidden');
      }
    }

    // Check if she already responded to this invitation
    const { data: existing } = await supabase
      .from('invitation_responses')
      .select('response')
      .eq('invitation_id', invitationId)
      .order('created_at', { ascending: false })
      .limit(1)
      .maybeSingle();

    if (existing?.response) {
      showThanks(existing.response);
      return;
    }

    // No existing response — show buttons and wire up handlers
    if (buttonsEl) buttonsEl.style.display = 'flex';

    buttonsEl?.querySelectorAll<HTMLButtonElement>('[data-response]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const response = btn.dataset.response as 'accepted' | 'declined';
        buttonsEl.querySelectorAll<HTMLButtonElement>('button').forEach(b => b.disabled = true);

        const { error } = await supabase.from('invitation_responses').insert({
          invitation_id: invitationId,
          response,
        });

        if (error) {
          buttonsEl.querySelectorAll<HTMLButtonElement>('button').forEach(b => b.disabled = false);
          if (errorEl) {
            errorEl.style.display = 'block';
            errorEl.removeAttribute('aria-hidden');
          }
          return;
        }

        showThanks(response);
      });
    });
  })();
</script>
